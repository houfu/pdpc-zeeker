# TAILSCALE_PROXY is required — PDPC blocks data-centre IPs, needs residential proxy
# Set automatically by NanoClaw when Tailscale sidecar is active
TAILSCALE_PROXY=socks5h://172.17.0.1:1055

# Docling server for PDF text extraction
# PDF bytes are fetched via Tailscale proxy then uploaded to this server
DOCLING_SERVE_URL=http://localhost:5001

# S3 deployment
S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
S3_ENDPOINT_URL=https://your-s3-endpoint.com
